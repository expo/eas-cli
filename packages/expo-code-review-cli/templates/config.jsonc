{
  // Default model for every agent. Override per-agent below, or at runtime with
  // the REVIEWER_MODEL env var (e.g. REVIEWER_MODEL=openai/gpt-5.4-mini-fast).
  "model": "anthropic/claude-sonnet-4-5",

  // Prepended to every agent + the coordinator prompt.
  "sharedPrompt": "prompts/shared.md",

  "coordinator": { "prompt": "prompts/coordinator.md" },

  // Add, remove, or re-scope agents freely. Each id must be unique.
  "agents": [
    { "id": "correctness", "prompt": "prompts/correctness.md" },
    { "id": "security", "prompt": "prompts/security.md" }
  ],

  "policy": {
    // Phase 1: keep signal high by surfacing only critical/warning.
    "includeSuggestions": false
    // "maxFindings": 10
  },

  // Files to always skip, in addition to the built-in defaults (lockfiles,
  // *.min.js, *.map, __snapshots__/*.snap, @generated markers).
  "noise": { "additionalIgnores": [] },

  // A maintainer comment containing this marker skips the CI review.
  "breakGlass": { "marker": "/skip-review" },

  // HTML marker used to find + update the single PR comment. Keep it stable.
  "commentTag": "expo-ai-code-reviewer"
}
