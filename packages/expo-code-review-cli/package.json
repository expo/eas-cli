{
  "name": "expo-code-review",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Generic, config-driven AI code reviewer engine. Repos supply their agents via .expo-code-review/.",
  "bin": {
    "ecr": "build/cli.js",
    "expo-code-review": "build/cli.js"
  },
  "files": [
    "build",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/cli.ts",
    "test:unit": "bun test"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.18.2",
    "opencode-ai": "^1.18.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.8",
    "rimraf": "3.0.2",
    "typescript": "5.5.4"
  }
}
