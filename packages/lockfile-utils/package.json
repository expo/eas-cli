{
  "name": "@expo/lockfile-utils",
  "description": "Parse npm, yarn, pnpm, and bun lockfiles and validate them against package.json for version mismatches and peer dependency conflicts",
  "version": "18.0.1",
  "bugs": "https://github.com/expo/eas-cli/issues",
  "license": "MIT",
  "author": "Expo <support@expo.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/eas-cli.git",
    "directory": "packages/lockfile-utils"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "yarn watch",
    "watch": "tsc --watch --preserveWatchOutput",
    "build": "tsc",
    "typecheck": "tsc",
    "prepack": "rm -rf dist *.tsbuildinfo && tsc -p tsconfig.build.json",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "clean": "rm -rf node_modules dist coverage *.tsbuildinfo"
  },
  "dependencies": {
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "20.14.2",
    "@types/semver": "^7.5.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.5.4"
  }
}
