{
  // Default model for every agent. Override at runtime with REVIEWER_MODEL
  // (e.g. REVIEWER_MODEL=openai/gpt-5.4-mini-fast for a cheaper local run).
  "model": "anthropic/claude-sonnet-4-5",

  "sharedPrompt": "prompts/shared.md",
  "coordinator": { "prompt": "prompts/coordinator.md" },

  "agents": [
    { "id": "correctness", "prompt": "prompts/correctness.md" },
    { "id": "security", "prompt": "prompts/security.md" }
  ],

  "policy": { "includeSuggestions": false },

  // eas-cli is yarn+lerna; skip built output that occasionally lands in diffs.
  "noise": {
    "additionalIgnores": ["packages/*/build/**", "packages/*/dist/**"]
  },

  "breakGlass": { "marker": "/skip-review" },
  "commentTag": "expo-ai-code-reviewer"
}
