{
  "name": "@expo/opencode-reviewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Two-agent AI code reviewer for eas-cli, runnable in CI or locally.",
  "bin": {
    "eas-review": "./src/entrypoints/cli.ts"
  },
  "scripts": {
    "review": "bun run src/entrypoints/cli.ts",
    "ci": "bun run src/entrypoints/ci.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.18.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.4"
  }
}
